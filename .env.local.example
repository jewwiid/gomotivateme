# =================================================================
# gomotivateme environment variables
# =================================================================
# Copy this file to `.env.local` and fill in the real values.
# Convex will write the dev values automatically when you run
# `npx convex dev` for the first time. Production values are set
# in the Vercel project settings.
# =================================================================

# --- Convex (dev) ---
# Set by `npx convex dev`. Keep this in `.env.local`, NOT in Vercel.
CONVEX_DEPLOY_KEY=

# --- Convex (public) ---
# Same value as the dev deployment URL while developing.
# In production, swap this for the URL from `npx convex deploy`.
NEXT_PUBLIC_CONVEX_URL=

# --- Convex (server-side, edge runtime) ---
# Same value as NEXT_PUBLIC_CONVEX_URL. Used by the dynamic OG
# image route which runs on the edge.
CONVEX_URL=

# --- App ---
# The canonical URL of the deployed site. Used in absolute
# share links shown in the dashboard and in OG image metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (Resend) ---
# The queue + templates are wired. Until these are set, the drain cron
# no-ops and emails stay "pending" in the notifications table — they'll
# send automatically once the key is added.
#
# Set on the Convex deployment (NOT Vercel — the action runs on Convex):
#   npx convex env set RESEND_API_KEY "re_xxxxx"
#   npx convex env set RESEND_FROM_ADDRESS "GoMotivateMe <hello@gomotivateme.com>"
RESEND_API_KEY=
RESEND_FROM_ADDRESS=GoMotivateMe <hello@gomotivateme.com>

# --- Content moderation (OpenAI) ---
# Set on the Convex deployment. Without it, new public content stays in the
# manual review queue instead of being published automatically.
#   npx convex env set OPENAI_API_KEY "sk-..."
OPENAI_API_KEY=
